# OpenAI API key (required for pipeline)
OPENAI_API_KEY=sk-...

# Postgres (sync URL for Alembic: postgresql://; async for app: postgresql+asyncpg://)
DATABASE_URL=postgresql://localhost/syllabus

# Auth
JWT_SECRET=change-me-in-production
# Google OAuth (optional)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
FRONTEND_URL=http://localhost:3000
API_URL=http://127.0.0.1:8000

# CORS: comma-separated allowed origins (required in production)
# Local default: http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Rate limiting (PRD 6.5): per-IP, in-memory. Format: limit/window (e.g. 100/minute, 30/second)
RATE_LIMIT_DEFAULT=100/minute
# Set to 1 or true when behind a trusted proxy to use X-Forwarded-For as client IP
# RATE_LIMIT_TRUST_PROXY=0

# Invite-only: comma-separated emails allowed to use generate/courses (e.g. beta@example.com)
# ALLOWED_EMAILS=beta@example.com

# RAG vector store (optional; fallback to stub if unset or empty)
# RAG_INDEX_PATH=.chroma_rag
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: override model names
# OPENAI_MODEL_INTENT=gpt-4o-mini
# OPENAI_MODEL_OUTLINE=gpt-4o
# OPENAI_MODEL_CONTENT=gpt-4o
# OPENAI_MODEL_QA=gpt-4o-mini

# --- Production (Railway backend) ---
# Set ALLOWED_ORIGINS to your Vercel app URL, e.g. https://your-app.vercel.app
# DATABASE_URL is auto-injected by Railway when you add Postgres.
# Set FRONTEND_URL and API_URL to production URLs for OAuth and redirects.
# Generate JWT_SECRET with: openssl rand -hex 32
