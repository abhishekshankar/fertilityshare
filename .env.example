# OpenAI API key (required for pipeline)
OPENAI_API_KEY=sk-...

# Postgres (sync URL for Alembic: postgresql://; async for app: postgresql+asyncpg://)
DATABASE_URL=postgresql://localhost/syllabus

# Auth
JWT_SECRET=change-me-in-production
# Google OAuth (optional)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
FRONTEND_URL=http://localhost:3000
API_URL=http://127.0.0.1:8000
# Invite-only: comma-separated emails allowed to use generate/courses (e.g. beta@example.com)
# ALLOWED_EMAILS=beta@example.com

# RAG vector store (optional; fallback to stub if unset or empty)
# RAG_INDEX_PATH=.chroma_rag
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: override model names
# OPENAI_MODEL_INTENT=gpt-4o-mini
# OPENAI_MODEL_OUTLINE=gpt-4o
# OPENAI_MODEL_CONTENT=gpt-4o
# OPENAI_MODEL_QA=gpt-4o-mini
